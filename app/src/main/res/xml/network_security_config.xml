<?xml version="1.0" encoding="utf-8"?>
<!--
  릴리스/기본 네트워크 보안 정책.
  - base-config: 평문 HTTP 차단 = 실도메인은 HTTPS 강제(운영 게이트웨이).
  - 개발 루프백(에뮬레이터 10.0.2.2 / localhost)만 평문 허용.
  공개 레포라 특정 dev 게이트웨이 IP(예: Tailscale)는 커밋하지 않음.
  디버그 빌드는 src/debug/res/xml 의 전체-평문 오버라이드로 임의 dev 호스트에 도달한다.
  데모용 release APK 를 평문 dev 게이트웨이로 붙이려면 이 파일에 해당 호스트 domain-config 를
  로컬에서 추가(커밋 금지)하거나 https 게이트웨이를 사용할 것.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
